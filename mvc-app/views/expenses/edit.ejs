<%- include('../partials/header') %>
<% let activePage = 'expenses' %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="page-header">
    <div>
      <a href="/expenses/<%= expense._id %>" class="back-link">&larr; Back to Expense</a>
      <h1>Edit Expense</h1>
    </div>
  </div>

  <%- include('../partials/flash') %>

  <div class="form-card card">
    <form action="/expenses/<%= expense._id %>?_method=PUT" method="POST" class="form">
      <div class="form-group">
        <label for="title">Title <span class="required">*</span></label>
        <input type="text" id="title" name="title" class="form-input" value="<%= expense.title %>" required minlength="2" maxlength="100" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="amount">Amount ($) <span class="required">*</span></label>
          <input type="number" id="amount" name="amount" class="form-input" value="<%= expense.amount %>" step="0.01" min="0.01" required />
        </div>
        <div class="form-group">
          <label for="date">Date <span class="required">*</span></label>
          <input type="date" id="date" name="date" class="form-input" value="<%= new Date(expense.date).toISOString().split('T')[0] %>" required />
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" class="form-input form-textarea" maxlength="500"><%= expense.description || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Categories <span class="hint">(select one or more)</span></label>
        <div class="checkbox-grid">
          <% const selectedIds = expense.categories.map(c => c._id.toString()) %>
          <% categories.forEach(cat => { %>
            <label class="checkbox-item">
              <input type="checkbox" name="categories" value="<%= cat._id %>"
                <%= selectedIds.includes(cat._id.toString()) ? 'checked' : '' %> />
              <span class="checkbox-label" style="border-color:<%= cat.color %>55;color:<%= cat.color %>"><%= cat.name %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <div class="form-actions">
        <a href="/expenses/<%= expense._id %>" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
