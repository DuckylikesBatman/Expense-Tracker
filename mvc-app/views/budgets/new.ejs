<%- include('../partials/header') %>
<% let activePage = 'budgets' %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="page-header">
    <div>
      <a href="/budgets" class="back-link">&larr; Back to Budgets</a>
      <h1>New Budget</h1>
    </div>
  </div>

  <%- include('../partials/flash') %>

  <div class="form-card card">
    <form action="/budgets" method="POST" class="form">
      <div class="form-group">
        <label for="name">Budget Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" class="form-input" placeholder="e.g. Monthly Food Budget" required minlength="2" maxlength="100" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="amount">Limit Amount ($) <span class="required">*</span></label>
          <input type="number" id="amount" name="amount" class="form-input" placeholder="500.00" step="0.01" min="1" required />
        </div>
        <div class="form-group">
          <label for="period">Period <span class="required">*</span></label>
          <select id="period" name="period" class="form-input form-select" required>
            <option value="weekly">Weekly</option>
            <option value="monthly" selected>Monthly</option>
            <option value="yearly">Yearly</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="startDate">Start Date <span class="required">*</span></label>
          <input type="date" id="startDate" name="startDate" class="form-input" value="<%= new Date().toISOString().split('T')[0] %>" required />
        </div>
        <div class="form-group">
          <label for="endDate">End Date <span class="required">*</span></label>
          <input type="date" id="endDate" name="endDate" class="form-input" required />
        </div>
      </div>
      <div class="form-group">
        <label for="category">Category <span class="required">*</span></label>
        <select id="category" name="category" class="form-input form-select" required>
          <option value="">-- Select a category --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>"><%= cat.name %></option>
          <% }) %>
        </select>
        <% if (categories.length === 0) { %>
          <p class="hint">No categories exist. <% if (user.role === 'admin') { %><a href="/categories/new" class="auth-link">Create one first.</a><% } %></p>
        <% } %>
      </div>
      <div class="form-actions">
        <a href="/budgets" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Budget</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
