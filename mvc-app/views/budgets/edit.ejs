<%- include('../partials/header') %>
<% let activePage = 'budgets' %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="page-header">
    <div>
      <a href="/budgets/<%= budget._id %>" class="back-link">&larr; Back to Budget</a>
      <h1>Edit Budget</h1>
    </div>
  </div>

  <%- include('../partials/flash') %>

  <div class="form-card card">
    <form action="/budgets/<%= budget._id %>?_method=PUT" method="POST" class="form">
      <div class="form-group">
        <label for="name">Budget Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" class="form-input" value="<%= budget.name %>" required minlength="2" maxlength="100" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="amount">Limit Amount ($) <span class="required">*</span></label>
          <input type="number" id="amount" name="amount" class="form-input" value="<%= budget.amount %>" step="0.01" min="1" required />
        </div>
        <div class="form-group">
          <label for="period">Period <span class="required">*</span></label>
          <select id="period" name="period" class="form-input form-select" required>
            <option value="weekly" <%= budget.period === 'weekly' ? 'selected' : '' %>>Weekly</option>
            <option value="monthly" <%= budget.period === 'monthly' ? 'selected' : '' %>>Monthly</option>
            <option value="yearly" <%= budget.period === 'yearly' ? 'selected' : '' %>>Yearly</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="startDate">Start Date <span class="required">*</span></label>
          <input type="date" id="startDate" name="startDate" class="form-input" value="<%= new Date(budget.startDate).toISOString().split('T')[0] %>" required />
        </div>
        <div class="form-group">
          <label for="endDate">End Date <span class="required">*</span></label>
          <input type="date" id="endDate" name="endDate" class="form-input" value="<%= new Date(budget.endDate).toISOString().split('T')[0] %>" required />
        </div>
      </div>
      <div class="form-group">
        <label for="category">Category <span class="required">*</span></label>
        <select id="category" name="category" class="form-input form-select" required>
          <option value="">-- Select a category --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>" <%= budget.category && budget.category.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-actions">
        <a href="/budgets/<%= budget._id %>" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
