<%- include('../partials/header') %>
<% let activePage = 'categories' %>
<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="page-header">
    <div>
      <a href="/categories/<%= category._id %>" class="back-link">&larr; Back to Category</a>
      <h1>Edit Category</h1>
    </div>
  </div>

  <%- include('../partials/flash') %>

  <div class="form-card card">
    <form action="/categories/<%= category._id %>?_method=PUT" method="POST" class="form">
      <div class="form-group">
        <label for="name">Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" class="form-input" value="<%= category.name %>" required minlength="2" maxlength="50" />
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" class="form-input form-textarea" maxlength="200"><%= category.description || '' %></textarea>
      </div>
      <div class="form-group">
        <label for="color">Color</label>
        <div class="color-row">
          <input type="color" id="color" name="color" class="color-picker" value="<%= category.color %>" />
          <span class="hint">Pick a color for this category badge</span>
        </div>
      </div>
      <div class="form-actions">
        <a href="/categories/<%= category._id %>" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
